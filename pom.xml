<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>org.springframework.boot</groupId>
    <artifactId>spring-boot-starter-parent</artifactId>
    <version>4.1.0</version>
    <relativePath/> <!-- resolve from repository -->
  </parent>

  <groupId>io.github.degdev</groupId>
  <artifactId>nobilis-platform</artifactId>
  <version>0.1.0-SNAPSHOT</version>
  <packaging>pom</packaging>

  <name>nobilis-platform</name>
  <description>Universal open-source web engine (backend core).</description>

  <properties>
    <java.version>25</java.version>

    <!--
      Explicit even though spring-boot-starter-parent already sets this for compilation — makes
      the repo self-documenting. The forked surefire test JVM does NOT inherit this; it gets
      file.encoding/sun.jnu.encoding via the surefire argLine below instead.
    -->
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <maven.compiler.encoding>UTF-8</maven.compiler.encoding>

    <!-- Code-style tooling (machine layer); versions pinned, no ranges. -->
    <spotless-maven-plugin.version>3.7.0</spotless-maven-plugin.version>
    <google-java-format.version>1.35.0</google-java-format.version>
    <maven-checkstyle-plugin.version>3.6.0</maven-checkstyle-plugin.version>
    <checkstyle.version>13.6.0</checkstyle.version>

    <!-- Lombok: 1.18.40 added JDK 25 support; 1.18.46 is the current release (verified June 2026). -->
    <lombok.version>1.18.46</lombok.version>
  </properties>

  <modules>
    <module>common</module>
    <module>ai</module>
    <module>auth</module>
    <module>app</module>
    <module>admin</module>
    <module>integration</module>
  </modules>

  <dependencyManagement>
    <dependencies>
      <!-- Internal module versions, centrally pinned to the reactor version. -->
      <dependency>
        <groupId>io.github.degdev</groupId>
        <artifactId>common</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>io.github.degdev</groupId>
        <artifactId>auth</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>io.github.degdev</groupId>
        <artifactId>ai</artifactId>
        <version>${project.version}</version>
      </dependency>

      <!--
        Lombok — compile-time boilerplate generation, provided scope (annotation processor +
        compile-time API only; nothing ships at runtime). Version pinned here; modules opt in by
        declaring the dependency without a version.
      -->
      <dependency>
        <groupId>org.projectlombok</groupId>
        <artifactId>lombok</artifactId>
        <version>${lombok.version}</version>
        <scope>provided</scope>
      </dependency>
    </dependencies>
  </dependencyManagement>

  <build>
    <plugins>
      <!--
        Compiler. Lombok rewrites the javac AST, which JEP 396 strong encapsulation (JDK 16+)
        blocks on JDK 25; the build forks javac and opens the compiler-internal packages Lombok
        needs (jdk.compiler/com.sun.tools.javac.*) so annotation processing is error- and
        warning-free. `-proc:full` names processing explicitly, silencing javac's "processors found
        on the class path" warning (JDK 21+). The annotation processors themselves (Lombok,
        spring-boot-configuration-processor) are discovered from the `provided`/optional classpath.
      -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <configuration>
          <proc>full</proc>
          <fork>true</fork>
          <compilerArgs>
            <arg>-J--add-opens=jdk.compiler/com.sun.tools.javac.api=ALL-UNNAMED</arg>
            <arg>-J--add-opens=jdk.compiler/com.sun.tools.javac.code=ALL-UNNAMED</arg>
            <arg>-J--add-opens=jdk.compiler/com.sun.tools.javac.comp=ALL-UNNAMED</arg>
            <arg>-J--add-opens=jdk.compiler/com.sun.tools.javac.file=ALL-UNNAMED</arg>
            <arg>-J--add-opens=jdk.compiler/com.sun.tools.javac.jvm=ALL-UNNAMED</arg>
            <arg>-J--add-opens=jdk.compiler/com.sun.tools.javac.main=ALL-UNNAMED</arg>
            <arg>-J--add-opens=jdk.compiler/com.sun.tools.javac.model=ALL-UNNAMED</arg>
            <arg>-J--add-opens=jdk.compiler/com.sun.tools.javac.parser=ALL-UNNAMED</arg>
            <arg>-J--add-opens=jdk.compiler/com.sun.tools.javac.processing=ALL-UNNAMED</arg>
            <arg>-J--add-opens=jdk.compiler/com.sun.tools.javac.tree=ALL-UNNAMED</arg>
            <arg>-J--add-opens=jdk.compiler/com.sun.tools.javac.util=ALL-UNNAMED</arg>
          </compilerArgs>
        </configuration>
      </plugin>

      <!--
        Surefire — force the forked test JVM to UTF-8 regardless of the OS locale. file.encoding
        and sun.jnu.encoding can only be overridden via argLine (JRE caches them; systemProperty-
        Variables is too late — see Surefire docs). Without this, a C-locale runner (e.g. CI with
        LC_ALL=C) forks the test JVM with sun.jnu.encoding=ANSI_X3.4-1968 and mangles non-ASCII
        (e.g. Cyrillic) test data/assertions even though the app itself is UTF-8-configured.
        No other plugin in this reactor sets argLine, so nothing to append to (yet) — if one is
        added later (e.g. JaCoCo), append to @{argLine} instead of overwriting it.
      -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-surefire-plugin</artifactId>
        <configuration>
          <argLine>-Dfile.encoding=UTF-8 -Dsun.jnu.encoding=UTF-8</argLine>
        </configuration>
      </plugin>

      <!--
        Spotless + google-java-format (Google Java Style). The check goal is gated in `verify`;
        run `mvn spotless:apply` to auto-format. google-java-format needs the JDK compiler
        internals opened — see .mvn/jvm.config.
      -->
      <plugin>
        <groupId>com.diffplug.spotless</groupId>
        <artifactId>spotless-maven-plugin</artifactId>
        <version>${spotless-maven-plugin.version}</version>
        <configuration>
          <java>
            <googleJavaFormat>
              <version>${google-java-format.version}</version>
            </googleJavaFormat>
          </java>
        </configuration>
        <executions>
          <execution>
            <id>spotless-check</id>
            <phase>verify</phase>
            <goals>
              <goal>check</goal>
            </goals>
          </execution>
        </executions>
      </plugin>

      <!--
        Checkstyle — light ruleset for what the formatter does not catch: naming,
        no wildcard imports, import/member ordering. The check goal is gated in `verify`.
      -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-checkstyle-plugin</artifactId>
        <version>${maven-checkstyle-plugin.version}</version>
        <dependencies>
          <dependency>
            <groupId>com.puppycrawl.tools</groupId>
            <artifactId>checkstyle</artifactId>
            <version>${checkstyle.version}</version>
          </dependency>
        </dependencies>
        <configuration>
          <configLocation>${maven.multiModuleProjectDirectory}/config/checkstyle/checkstyle.xml</configLocation>
          <includeTestSourceDirectory>true</includeTestSourceDirectory>
          <consoleOutput>true</consoleOutput>
          <failsOnError>true</failsOnError>
          <violationSeverity>error</violationSeverity>
        </configuration>
        <executions>
          <execution>
            <id>checkstyle-check</id>
            <phase>verify</phase>
            <goals>
              <goal>check</goal>
            </goals>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
</project>

<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>org.springframework.boot</groupId>
    <artifactId>spring-boot-starter-parent</artifactId>
    <version>4.1.0</version>
    <relativePath/> <!-- resolve from repository -->
  </parent>

  <groupId>io.github.degdev</groupId>
  <artifactId>nobilis-platform</artifactId>
  <version>0.1.0-SNAPSHOT</version>
  <packaging>pom</packaging>

  <name>nobilis-platform</name>
  <description>Universal open-source web engine (backend core).</description>

  <properties>
    <java.version>25</java.version>
  </properties>

  <modules>
    <module>common</module>
    <module>ai</module>
    <module>auth</module>
    <module>app</module>
    <module>admin</module>
    <module>integration</module>
  </modules>

  <dependencyManagement>
    <dependencies>
      <!-- Internal module versions, centrally pinned to the reactor version. -->
      <dependency>
        <groupId>io.github.degdev</groupId>
        <artifactId>common</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>io.github.degdev</groupId>
        <artifactId>auth</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>io.github.degdev</groupId>
        <artifactId>ai</artifactId>
        <version>${project.version}</version>
      </dependency>
    </dependencies>
  </dependencyManagement>
</project>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  nobilis-platform — light Checkstyle ruleset.

  Scope: ONLY what google-java-format (via Spotless) does not already enforce —
  naming conventions, no wildcard imports, and import/member ordering. Whitespace,
  indentation, line length, braces, etc. are owned by the formatter and intentionally
  left out here to avoid duplicate/conflicting rules.

  Derived from Google Java Style (the project's named style standard; see docs/conventions.md).
-->
<module name="Checker">
  <property name="severity" value="error"/>
  <property name="charset" value="UTF-8"/>
  <property name="fileExtensions" value="java"/>

  <module name="TreeWalker">

    <!-- Naming conventions -->
    <module name="PackageName">
      <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
    </module>
    <module name="TypeName"/>
    <module name="MethodName"/>
    <module name="MemberName"/>
    <module name="ParameterName"/>
    <module name="LocalVariableName"/>
    <module name="LocalFinalVariableName"/>
    <module name="ConstantName"/>
    <module name="StaticVariableName"/>

    <!-- Imports: no wildcards; deterministic order matching google-java-format -->
    <module name="AvoidStarImport"/>
    <module name="CustomImportOrder">
      <property name="sortImportsInGroupAlphabetically" value="true"/>
      <property name="separateLineBetweenGroups" value="true"/>
      <property name="customImportOrderRules" value="STATIC###THIRD_PARTY_PACKAGE"/>
    </module>

    <!-- Member ordering -->
    <module name="DeclarationOrder"/>
    <module name="OverloadMethodsDeclarationOrder"/>

  </module>
</module>

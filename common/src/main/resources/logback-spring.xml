<?xml version="1.0" encoding="UTF-8"?>
<!--
  Shared logging config for all three runnables (app/admin/integration). Lives in common's jar,
  so it is on every runnable's classpath and Spring Boot picks it up automatically as
  classpath:logback-spring.xml — no per-runnable file, no <include> across the module boundary.
  Each runnable sets only logging.file.name (its own log file) and logging.level.* in its own
  application.properties; rotation policy is fixed here so it cannot drift between runnables.

  This file is ALSO on the classpath of common/auth/ai's own tests (they depend on common, or
  common IS the module), where logging.file.name is never set — Boot then leaves its own LOG_FILE
  property undefined, and an unconditional ${LOG_FILE} resolves to a literal garbage filename. The
  springProperty default below keeps LOG_FILE always defined, so any context lacking
  logging.file.name falls back to logs/application.log instead.
-->
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <springProperty scope="context" name="LOG_FILE" source="logging.file.name" defaultValue="logs/application.log"/>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE}</file>
        <encoder>
            <pattern>${FILE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_FILE}.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>100MB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
